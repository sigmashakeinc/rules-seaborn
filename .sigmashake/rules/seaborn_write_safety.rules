# seaborn_write_safety.rules
# Technology: seaborn | Capability: write

rule seaborn-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "sns.tsplot"
  MESSAGE "Blocked an unsafe pattern in seaborn. Use the recommended best practices for 2025/2026."
}

rule seaborn-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "sns.factorplot"
  MESSAGE "You are using an outdated API for seaborn. Please upgrade to the newer API."
}
